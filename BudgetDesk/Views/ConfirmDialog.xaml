<Window x:Class="BudgetDesk.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">

    <Border Background="{DynamicResource CardBgBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: icon + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Border x:Name="IconBadge" Width="36" Height="36" CornerRadius="18"
                        Background="{DynamicResource NegativeBadgeBgBrush}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="IconGlyph" Text="!" FontSize="20" FontWeight="ExtraBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentRedBrush}"/>
                </Border>
                <TextBlock x:Name="TitleText" Text="Confirm" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Body -->
            <TextBlock Grid.Row="1" x:Name="BodyText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="13" TextWrapping="Wrap" LineHeight="20"
                       Margin="0,0,0,8"/>

            <!-- Backup hint -->
            <Border Grid.Row="2" x:Name="BackupHint"
                    Background="{DynamicResource WarningBadgeBgBrush}"
                    CornerRadius="6" Padding="10,8" Margin="0,8,0,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentOrangeBrush}"
                               VerticalAlignment="Top" Margin="0,1,8,0"/>
                    <TextBlock x:Name="BackupHintText"
                               Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="CancelBtn" Content="Cancel"
                        Style="{StaticResource ModernButton}"
                        MinWidth="96" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelBtn_Click"/>
                <Button x:Name="ConfirmBtn" Content="Confirm"
                        Style="{StaticResource DangerButton}"
                        MinWidth="140"
                        IsDefault="True"
                        Click="ConfirmBtn_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
